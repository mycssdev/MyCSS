  "foundations/scales": {
    "scale-base": {
      "$value": 16,
      "$type": "number",
      "$description": "Base size in px for the modular scale. Overridden by density themes."
    },
    "scale-ratio": {
      "$value": 1.25,
      "$type": "number",
      "$description": "Modular scale ratio (Major Third). Overridden by density themes."
    },
    "linear-base": {
      "$value": 4,
      "$type": "number",
      "$description": "Base increment in px for the linear spacing scale."
    }
  },
  "foundations/modular-scale": {
    "ms--3": {
      "$value": "round({scale-base} / {scale-ratio} / {scale-ratio} / {scale-ratio})",
      "$type": "dimension",
      "$description": "~8px at comfortable (16 / 1.25\u00c2\u00b3)"
    },
    "ms--2": {
      "$value": "round({scale-base} / {scale-ratio} / {scale-ratio})",
      "$type": "dimension",
      "$description": "~10px at comfortable (16 / 1.25\u00c2\u00b2)"
    },
    "ms--1": {
      "$value": "round({scale-base} / {scale-ratio})",
      "$type": "dimension",
      "$description": "~13px at comfortable (16 / 1.25)"
    },
    "ms-0": {
      "$value": "{scale-base}",
      "$type": "dimension",
      "$description": "16px at comfortable \u00e2\u20ac\u201d body text base"
    },
    "ms-1": {
      "$value": "round({scale-base} * {scale-ratio})",
      "$type": "dimension",
      "$description": "~20px at comfortable (16 \u00c3\u2014 1.25)"
    },
    "ms-2": {
      "$value": "round({ms-1} * {scale-ratio})",
      "$type": "dimension",
      "$description": "~25px at comfortable (16 \u00c3\u2014 1.25\u00c2\u00b2)"
    },
    "ms-3": {
      "$value": "round({ms-2} * {scale-ratio})",
      "$type": "dimension",
      "$description": "~31px at comfortable (16 \u00c3\u2014 1.25\u00c2\u00b3)"
    },
    "ms-4": {
      "$value": "round({ms-3} * {scale-ratio})",
      "$type": "dimension",
      "$description": "~39px at comfortable (16 \u00c3\u2014 1.25\u00e2\u0081\u00b4)"
    },
    "ms-5": {
      "$value": "round({ms-4} * {scale-ratio})",
      "$type": "dimension",
      "$description": "~49px at comfortable (16 \u00c3\u2014 1.25\u00e2\u0081\u00b5)"
    },
    "ms-6": {
      "$value": "round({ms-5} * {scale-ratio})",
      "$type": "dimension",
      "$description": "~61px at comfortable (16 \u00c3\u2014 1.25\u00e2\u0081\u00b6)"
    },
    "ms-7": {
      "$value": "round({ms-6} * {scale-ratio})",
      "$type": "dimension",
      "$description": "~76px at comfortable (16 \u00c3\u2014 1.25\u00e2\u0081\u00b7)"
    },
    "ms-8": {
      "$value": "round({ms-7} * {scale-ratio})",
      "$type": "dimension",
      "$description": "~95px at comfortable (16 \u00c3\u2014 1.25\u00e2\u0081\u00b8)"
    }
  },
